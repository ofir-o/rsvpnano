# Optional advanced OTA override file.
# The normal setup flow is now on-device: Settings -> Wi-Fi -> Choose network.
# Copy this file to the SD card as /config/ota.conf only if you want a fallback
# or want to override the default repo/asset settings.

wifi_ssid=YourWiFiName
wifi_password=YourWiFiPassword

# Optional. Defaults point at the main RSVP Nano repo, and each board now chooses
# its own OTA asset automatically. You should not usually need to override
# `asset_name` unless you are testing a custom release channel.
# github_owner=ionutdecebal
# github_repo=rsvpnano
# asset_name=rsvp-nano-ota.bin

# Optional. When true, the device checks the latest GitHub Release during boot.
auto_check=false
